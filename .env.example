NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=learning_vocab
# Set to 'true' for managed Postgres that requires TLS over its public proxy
# (e.g. Railway). Leave 'false' for local Docker / private-network connections.
DB_SSL=false

# Comma-separated allowed CORS origins (production). Leave blank in dev to allow
# any origin. e.g. CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=

PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Login rate limit (per IP)
AUTH_LOGIN_THROTTLE_TTL=900
AUTH_LOGIN_THROTTLE_LIMIT=5

# Learning session HMAC. Generate with: openssl rand -base64 48
LEARN_HMAC_SECRET=change-me-learn-hmac-secret-at-least-32-bytes-long
LEARN_SIGNATURE_TTL_MS=1800000
LEARN_DEFAULT_SESSION_LIMIT=15
LEARN_MAX_SESSION_LIMIT=50

# Redis (BullMQ queue for background audio generation). Auth-less in dev.
# Managed hosts (Railway, Upstash, …) expose a single REDIS_URL — set it and the
# discrete host/port/password vars below are ignored. e.g. REDIS_URL=redis://default:pass@host:6379
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Vocabulary audio generation (worker + db:backfill-audio script)
# Cloudinary — CDN/object storage for generated pronunciation mp3s.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AUDIO_FOLDER=vocab-audio
# Edge-TTS — free fallback (no API key) when the dictionary has no recording.
# Any Edge neural voice ShortName, e.g. en-US-AriaNeural, en-GB-SoniaNeural.
TTS_VOICE=en-US-AriaNeural
# Audio worker: how many generation jobs to process in parallel.
AUDIO_WORKER_CONCURRENCY=5

# Practice scoring + quick-create enrichment (Google AI Studio, free tier).
# Get a key at https://aistudio.google.com/apikey
# Model: use a Gemini model, NOT gemma-* — Gemma-3 is retired and Gemma-4 are
# reasoning models that truncate JSON and ignore thinkingConfig. The callers send
# thinkingConfig.thinkingBudget=0, which only Gemini honours.
GEMMA_API_KEY=
GEMMA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMMA_MODEL=gemini-2.5-flash-lite
GEMMA_TIMEOUT_MS=30000
# Worker self-throttle to stay under the free-tier RPM, and parallelism.
GEMMA_REQUESTS_PER_MINUTE=15
GEMMA_WORKER_CONCURRENCY=1
# Per-user submissions allowed per UTC day (shared-key quota guard).
GEMMA_DAILY_ATTEMPTS_PER_USER=30
# Quick-create enrichment worker: parallelism. Per-word jobs now coalesce into
# one batched Gemma call (see ENRICHMENT_BATCH_SIZE), so set this >= the batch
# size so enough jobs run at once to fill a batch. GEMMA_REQUESTS_PER_MINUTE
# still caps job starts and is a safe upper bound on actual calls.
ENRICHMENT_WORKER_CONCURRENCY=5
# How many words share one Gemma enrichment call, and how long a partial batch
# waits (ms) for more words before flushing (a lone quick-create flushes after
# this delay). Set ENRICHMENT_BATCH_SIZE=1 to disable batching.
ENRICHMENT_BATCH_SIZE=5
ENRICHMENT_BATCH_LINGER_MS=300

# Vocabulary sense images (approval-time generation + db:backfill-image script).
# Pexels stock-photo search — free API key at https://www.pexels.com/api/
PEXELS_API_KEY=
# Reuses the Cloudinary account above; separate folder for sense images.
CLOUDINARY_IMAGE_FOLDER=vocab-images
# Image worker: how many generation jobs to process in parallel.
IMAGE_WORKER_CONCURRENCY=3

# Pronunciation scoring (phoneme-scoring microservice — POST /score).
# Run it locally with Docker (port 8000, no token) or point at the deployed
# private HF Space (set the URL + Bearer token below). The free Space sleeps
# after ~48h idle and cold-starts in 30–60s, hence the high timeout + retries.
# Never commit the real token.
PRONUNCIATION_SERVICE_URL=http://localhost:8000
PRONUNCIATION_SERVICE_TOKEN=
PRONUNCIATION_TIMEOUT_MS=60000
PRONUNCIATION_MAX_ATTEMPTS=3

# Mailer (SMTP). For local dev use Mailtrap or a Gmail app password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Learning Vocab <no-reply@example.com>"
