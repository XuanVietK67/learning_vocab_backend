@startuml activity-phien-hoc
skinparam dpi 150
skinparam defaultFontName Arial
title Phiên học theo cơ chế ôn tập ngắt quãng
start
:Người học chọn chế độ học\n(daily / topic / deck / review);
:Chọn từ phù hợp + tự ghi danh từ mới;
if (Có thẻ để học?) then (không)
  :Trả về lý do phiên rỗng + nextDueAt;
  stop
else (có)
endif
:Mở rộng mỗi từ thành chuỗi câu hỏi\n(dễ -> khó, ký HMAC);
repeat
  :Hiển thị câu hỏi;
  :Người học trả lời;
  :Xác thực HMAC + chấm điểm;
  if (Bước cuối của từ?) then (đúng)
    :Quy đổi điểm SM-2;
    :Cập nhật tiến độ + lịch ôn tập;
    :Ghi nhật ký hoạt động;
  else (chưa)
    :Chỉ phản hồi, chưa cập nhật;
  endif
repeat while (Còn câu hỏi?) is (còn) not (hết)
:Kết thúc phiên;
stop
@enduml

' ---------------------------------------------------------------------
@startuml activity-tao-nhanh-ai
skinparam dpi 150
skinparam defaultFontName Arial
title Tạo nhanh từ vựng bằng AI
|API|
start
:Nhận lemma + ngôn ngữ;
if (Đã có job pending cùng lemma?) then (có)
  :Trả về job cũ (202);
  stop
else (không)
  :Tạo job trạng thái pending;
  :Đẩy job vào hàng đợi BullMQ;
  :Trả về 202 + jobId;
endif
|Worker|
:Lấy job khỏi hàng đợi;
:Tra từ điển + gọi Gemma 3\n(nghĩa, ví dụ, bản dịch);
:Sinh âm thanh (TTS) + tải lên Cloudinary;
:Tạo bản ghi từ vựng (1 / từ loại);
:Cập nhật job = completed\n+ resultVocabularyIds;
|API|
:Người dùng thăm dò job lấy kết quả;
stop
@enduml

' ---------------------------------------------------------------------
@startuml activity-luyen-viet
skinparam dpi 150
skinparam defaultFontName Arial
title Luyện viết câu chấm điểm bất đồng bộ
|API|
start
:Nhận câu + từ mục tiêu + hình thức;
if (Vượt hạn mức ngày?) then (có)
  :Trả về 429;
  stop
else (không)
endif
:Tạo attempt = pending + enqueue;
:Trả về 202 + attemptId;
|Worker chấm điểm|
:Lấy attempt khỏi hàng đợi\n(giới hạn tần suất);
:Gọi Gemma 3 chấm theo rubric;
:Lưu điểm 0-100 + CEFR + nhận xét;
|API|
:Người học thăm dò attempt lấy kết quả;
stop
@enduml

