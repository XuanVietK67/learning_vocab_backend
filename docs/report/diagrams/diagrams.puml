@startuml erd
skinparam dpi 150
skinparam defaultFontName Arial
hide circle
skinparam shadowing false

entity users {
  * id : uuid <<PK>>
  --
  email : varchar <<unique>>
  password_hash : varchar
  role : enum
  is_onboarded : boolean
  target_language : varchar
  proficiency_level : enum
}
entity user_identities {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  provider : enum
  provider_user_id : varchar
}
entity refresh_tokens {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  token_hash : varchar
  expires_at : timestamptz
}
entity email_verification_codes {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  code_hash : varchar
  expires_at : timestamptz
}
entity vocabularies {
  * id : uuid <<PK>>
  --
  language : varchar
  lemma : varchar
  part_of_speech : enum
  cefr_level : enum
  source : enum
  visibility : enum
  is_approved : boolean
  created_by_user_id : uuid <<FK>>
}
entity vocabulary_senses {
  * id : uuid <<PK>>
  --
  vocabulary_id : uuid <<FK>>
  sense_order : smallint
  gloss : varchar
  definition : text
}
entity vocabulary_translations {
  * id : uuid <<PK>>
  --
  sense_id : uuid <<FK>>
  language : varchar
  translation : varchar
}
entity vocabulary_examples {
  * id : uuid <<PK>>
  --
  sense_id : uuid <<FK>>
  sentence : text
}
entity topics {
  * id : uuid <<PK>>
  --
  slug : varchar <<unique>>
  name : varchar
}
entity vocabulary_topics {
  * vocabulary_id : uuid <<PK,FK>>
  * topic_id : uuid <<PK,FK>>
}
entity decks {
  * id : uuid <<PK>>
  --
  name : varchar
  language : varchar
  owner_id : uuid <<FK>>
  visibility : enum
  vocab_count : int
}
entity deck_vocabularies {
  * deck_id : uuid <<PK,FK>>
  * vocabulary_id : uuid <<PK,FK>>
  --
  position : int
}
entity user_word_progress {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  vocabulary_id : uuid <<FK>>
  status : enum
  ease_factor : numeric
  interval_days : int
  next_review_at : timestamptz
}
entity learning_activity {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  vocabulary_id : uuid <<FK>>
  reviewed_at : timestamptz
  quality : smallint
  was_new : boolean
}
entity vocab_enrichment_jobs {
  * id : uuid <<PK>>
  --
  language : varchar
  lemma : varchar
  status : enum
  batch_id : uuid
  owner_user_id : uuid <<FK>>
}
entity production_attempts {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  vocabulary_id : uuid <<FK>>
  modality : enum
  status : enum
  score : int
}
entity pronunciation_attempts {
  * id : uuid <<PK>>
  --
  user_id : uuid <<FK>>
  vocabulary_id : uuid <<FK>>
  word : varchar
  overall_score : smallint
}

users ||--o{ user_identities
users ||--o{ refresh_tokens
users ||--o{ email_verification_codes
users ||--o{ user_word_progress
users ||--o{ learning_activity
users ||--o{ production_attempts
users ||--o{ pronunciation_attempts
users |o--o{ decks
users |o--o{ vocabularies
users |o--o{ vocab_enrichment_jobs
vocabularies ||--o{ vocabulary_senses
vocabulary_senses ||--o{ vocabulary_translations
vocabulary_senses ||--o{ vocabulary_examples
vocabularies ||--o{ vocabulary_topics
topics ||--o{ vocabulary_topics
decks ||--o{ deck_vocabularies
vocabularies ||--o{ deck_vocabularies
vocabularies ||--o{ user_word_progress
vocabularies |o--o{ learning_activity
vocabularies ||--o{ production_attempts
vocabularies |o--o{ pronunciation_attempts
@enduml

